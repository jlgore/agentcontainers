package sift.awk_scanning

import rego.v1

# awk/gawk/mawk/nawk execute arbitrary commands via language syntax, not
# flags. Scan positional (non-flag) program text for system(), getline,
# and pipe/redirect-into-string operators.
deny contains msg if {
	lower(input.parsed.binary) in {lower(t) | some t in data.awk_program_tools}
	some arg in input.parsed.args
	not startswith(arg, "-")
	regex.match(`{{.AwkDangerRegex}}`, arg)
	msg := sprintf("dangerous construct in %s program text (system(), getline, or pipe operators)", [input.parsed.binary])
}

{{.Header}}
package sift.decision

import rego.v1

# Aggregate every category's deny set into a single structured decision.
# Each reason is prefixed with its source package for traceability.
# allowed is true only when no category produced a deny.
{{range .PolicyPackages}}
reasons contains msg if {
	some r in data.sift.{{.}}.deny
	msg := sprintf("sift.{{.}}: %s", [r])
}
{{end}}
default allowed := false

allowed if count(reasons) == 0

policies_evaluated := [
{{- range .PolicyPackages}}
	"sift.{{.}}",
{{- end}}
]

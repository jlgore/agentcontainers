package sift.filesystem

import rego.v1

# agentcontainers-native: filesystem policy from agentcontainer.json
# policy.filesystem, enforced at the proxy on decomposed argument paths.
# This is the argument-level layer of the same policy the eBPF enforcer
# applies at the kernel (Phase 3) — defense in depth, not a substitute.
#
# Patterns may be plain directory prefixes ("/evidence") or globs with
# "/"-delimited wildcards ("/cases/*/extractions", "/proc/*/mem").
# Device paths (input.parsed.device_paths) are deliberately exempt from
# the read allowlist — disk-forensics tools address /dev specifiers,
# which path_policy and the kernel layer govern separately.

# Deny patterns match any referenced path, input or output.
deny contains msg if {
	some path in array.concat(input.parsed.paths, input.parsed.output_paths)
	some pattern in data.fs_deny
	_matches(path, pattern)
	msg := sprintf("path '%s' is denied by filesystem policy ('%s')", [path, pattern])
}

# A non-empty read allowlist confines every input path.
deny contains msg if {
	count(data.fs_read) > 0
	some path in input.parsed.paths
	not _matches_any(path, data.fs_read)
	msg := sprintf("read path '%s' is outside the filesystem read allowlist", [path])
}

# A non-empty write allowlist confines every output path.
deny contains msg if {
	count(data.fs_write) > 0
	some path in input.parsed.output_paths
	not _matches_any(path, data.fs_write)
	msg := sprintf("write path '%s' is outside the filesystem write allowlist", [path])
}

_matches_any(path, patterns) if {
	some pattern in patterns
	_matches(path, pattern)
}

# Plain prefix: the path is the directory or inside it.
_matches(path, pattern) if {
	not contains(pattern, "*")
	_inside(path, pattern)
}

# Glob: exact match, or any descendant of a matching directory.
_matches(path, pattern) if {
	contains(pattern, "*")
	glob.match(pattern, ["/"], path)
}

_matches(path, pattern) if {
	contains(pattern, "*")
	glob.match(concat("", [pattern, "/**"]), ["/"], path)
}

_inside(path, dir) if path == dir

_inside(path, dir) if startswith(path, sprintf("%s/", [dir]))

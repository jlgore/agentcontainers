{
  // Run an agent with the mainline SIFT forensic platform (AppliedIR/sift-mcp)
  // available as a single MCP tool, under agentcontainers enforcement.
  //
  // The "sift" tool is a container-type MCP server with the "http" transport:
  // the MCP proxy (agentcontainer mcp start) launches the sift-gateway image as
  // a hardened sidecar (caps dropped, no-new-privileges) on a private bridge
  // network, registers its cgroup with the eBPF enforcer, and proxies its HTTP
  // MCP endpoint to the agent. The gateway itself aggregates forensic-mcp,
  // sift-mcp, case-mcp, report-mcp.
  //
  // Build the image first:  ./build.sh   (produces sift-gateway:demo)
  "name": "sift-agent",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "agent": {
    "capabilities": {
      "filesystem": {
        "read": ["/workspace/**"],
        "write": ["/workspace/**"]
      },
      "network": {
        "egress": [
          { "host": "api.github.com", "port": 443 }
        ]
      }
    },

    "tools": {
      "mcp": {
        // The sift-gateway is an HTTP MCP server. agentcontainers hosts it as a
        // container-type backend over the "http" transport: the MCP proxy
        // launches the image itself, freezes it, registers its cgroup with the
        // eBPF enforcer (default-deny egress applied to its BPF maps — the
        // gateway's 4 sub-servers are local stdio subprocesses, so it needs no
        // outbound network), unfreezes, then connects to its Streamable HTTP
        // endpoint at :4508/mcp over the per-session bridge. The gateway is
        // kernel-enforced, not just the proxy in front of it.
        //
        // The proxy owns the gateway lifecycle — no standalone `docker run` is
        // needed. `mcp start` requires a running enforcer for container backends
        // (set agent.enforcer.required: false to opt out). On a plain Docker
        // Engine host this proxy path is the supported way to host container MCP
        // tools; the in-`run` container-tool path needs the sandbox runtime
        // (Docker Desktop).
        "sift": {
          "type": "container",
          "image": "sift-gateway:demo",
          "transport": "http",
          "port": 4508,
          "path": "/mcp"
        }
      }
    },

    "policy": {
      "escalation": "prompt",
      "auditLog": true,
      "onCapabilityViolation": "deny"
    }
  }
}

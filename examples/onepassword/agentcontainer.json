{
  // 1Password secrets provider example.
  // Uses the "1password" provider via the `op` CLI.
  // Requires 1Password desktop app for biometric approval.
  // Inherits filesystem, network, and policy from ../_base; overrides
  // shell.commands to add "npm run build".
  "extends": "../_base/agentcontainer.json",
  "name": "onepassword-agent",

  "agent": {
    "capabilities": {
      // Arrays replace on merge, so re-list the base commands plus the extra.
      "shell": {
        "commands": [
          "npm install",
          "npm test",
          "npm run build",
          "git status",
          "git diff"
        ]
      }
    },

    "secrets": {
      // GitHub token stored in 1Password.
      // Reference the item with structured vault/item/field fields.
      "GITHUB_TOKEN": {
        "provider": "1password",
        "vault": "Development",
        "item": "GitHub PAT",
        "field": "credential",
        "ttl": "1h",
        "allowedTools": ["mcp-github"]
      },

      // NPM publish token from 1Password.
      "NPM_TOKEN": {
        "provider": "1password",
        "vault": "Development",
        "item": "npm Registry",
        "field": "token",
        "ttl": "4h"
      },

      // Database connection string from 1Password.
      "DATABASE_URL": {
        "provider": "1password",
        "vault": "Development",
        "item": "Staging DB",
        "field": "connection-string",
        "ttl": "1h",
        "allowedTools": ["mcp-postgres"]
      }
    }
  }
}
